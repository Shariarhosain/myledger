# Server Configuration
PORT=5000
NODE_ENV=production
BASE_URL=https://backend-therellwalker.mtscorporate.com

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/therellwalker?schema=public"

# JWT
JWT_SECRET=your-jwt-secret-key-here

# Session
SESSION_SECRET=your-session-secret-key-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://backend-therellwalker.mtscorporate.com/api/auth/google/callback

# Email Configuration (for OTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Frontend URL (for CORS)
FRONTEND_URL=https://therellwalker.mtscorporate.com
