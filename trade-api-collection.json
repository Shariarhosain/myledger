{
  "client": "Thunder Client",
  "collectionName": "Trade API",
  "dateExported": "2025-10-28",
  "version": "1.1",
  "folders": [
    {
      "name": "Trades",
      "requests": [
        {
          "name": "Create Trade",
          "method": "POST",
          "url": "{{baseUrl}}/api/trades",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{accessToken}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": {
            "type": "json",
            "raw": "{\n  \"date\": \"2025-10-28\",\n  \"time\": \"09:30:00\",\n  \"ticker\": \"NQ\",\n  \"direction\": \"Long\",\n  \"entryPrice\": 16000,\n  \"exitPrice\": 16100,\n  \"stopLoss\": 15950,\n  \"takeProfit\": 16150,\n  \"quantity\": 1,\n  \"notes\": \"Strong breakout pattern\"\n}"
          }
        },
        {
          "name": "Get All Trades",
          "method": "GET",
          "url": "{{baseUrl}}/api/trades",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{accessToken}}"
            }
          ]
        },
        {
          "name": "Get Single Trade",
          "method": "GET",
          "url": "{{baseUrl}}/api/trades/{{tradeId}}",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{accessToken}}"
            }
          ]
        },
        {
          "name": "Update Trade",
          "method": "PUT",
          "url": "{{baseUrl}}/api/trades/{{tradeId}}",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{accessToken}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": {
            "type": "json",
            "raw": "{\n  \"exitPrice\": 16150,\n  \"notes\": \"Updated exit price\"\n}"
          }
        },
        {
          "name": "Delete Trade",
          "method": "DELETE",
          "url": "{{baseUrl}}/api/trades/{{tradeId}}",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{accessToken}}"
            }
          ]
        },
        {
          "name": "Get Dashboard Stats",
          "method": "GET",
          "url": "{{baseUrl}}/api/trades/dashboard",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{accessToken}}"
            }
          ]
        }
      ]
    },
