        }
      ]
    }
  ],
  "environments": [
    {
      "name": "Local",
      "variables": [
        {
          "name": "baseUrl",
          "value": "http://localhost:5000"
        },
        {
          "name": "accessToken",
          "value": "your_jwt_token_here"
        },
        {
          "name": "tradeId",
          "value": "trade_uuid_here"
        }
      ]
    },
    {
      "name": "Production",
      "variables": [
        {
          "name": "baseUrl",
          "value": "https://therellwalker.mtscorporate.com"
        },
        {
          "name": "accessToken",
          "value": "your_jwt_token_here"
        },
        {
